# ================================================
# Supabase Configuration
# Create a project at https://supabase.com and add your credentials here

# Your Supabase project URL (found in Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon key (found in Settings > API > Project API keys)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ================================================
# Cloudinary Configuration
# Create an account at https://cloudinary.com and add your credentials here

# Your Cloudinary cloud name (found in Dashboard)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Your Cloudinary API key (found in Settings > API)
VITE_CLOUDINARY_API_KEY=your-api-key

# Your Cloudinary API secret (found in Settings > API)
VITE_CLOUDINARY_API_SECRET=your-api-secret

# Optional: Upload preset for unsigned uploads
# VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ================================================
# Email Configuration (for Netlify Functions)
# Configure your SMTP server or email provider

# SMTP Settings
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-username
EMAIL_PASS=your-smtp-password
EMAIL_FROM=noreply@agighana.org
EMAIL_FROM_NAME=AGI ACCRA

# Email Provider (optional - for advanced providers)
# Options: smtp (default), sendgrid, mailgun, ses
# EMAIL_PROVIDER=smtp

# SendGrid Configuration (if using SendGrid)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Mailgun Configuration (if using Mailgun)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=your-mailgun-domain

# AWS SES Configuration (if using AWS SES)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
